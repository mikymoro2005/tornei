# Copia come `.env` in locale. Su Vercel: stesse chiavi in Environment Variables (non committare `.env`).
# Valori reali: Supabase → Project Settings → API.

VITE_SUPABASE_URL=https://TUA-REF.supabase.co
VITE_SUPABASE_ANON_KEY=anon_o_publishable_key_da_dashboard

VITE_APP_URL=https://tornei.vercel.app
VITE_OWNER_BASE_PATH=/owner
VITE_PRIMARY_SITE_HOSTS=tornei.vercel.app

# Script `npm run provision:organizer` → solo in `.env.provision` (gitignored)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# PUBLIC_APP_URL=https://tornei.vercel.app
# OWNER_BASE_PATH=/owner
