# Progetto Vercel: nome “tornei” → deploy https://tornei.vercel.app

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon...

# URL pubblico del sito (nome progetto tornei)
VITE_APP_URL=https://tornei.vercel.app

# Portale proprietario credenziali: https://tornei.vercel.app/owner/login
VITE_OWNER_BASE_PATH=/owner

# Homepage marketing su tornei.vercel.app (comma se servono più hostname)
VITE_PRIMARY_SITE_HOSTS=tornei.vercel.app

# ── Script locale `npm run provision:organizer` (file `.env.provision`, mai in git) ──
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=xxxx
# PUBLIC_APP_URL=https://tornei.vercel.app
# OWNER_BASE_PATH=/owner
